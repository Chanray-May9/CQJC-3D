{
  "name": "campus3d",
  "version": "0.2.0",
  "description": "时空战场 · 团队竞技枪战(重庆建筑工程职业学院校园)",
  "scripts": {
    "dev": "vite --port 5183 --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --port 5183",
    "textures": "python tools/fetch_textures.py",
    "test": "node --test test/*.test.js",
    "test:combat": "node tools/combat-test.mjs",
    "test:ai": "node tools/ai-test.mjs",
    "test:flow": "node tools/flow-test.mjs",
    "shots": "node tools/shoot.mjs shots",
    "deploy": "npm run build && node tools/deploy-pages.mjs"
  },
  "type": "module",
  "dependencies": {
    "three": "^0.185.1",
    "three-mesh-bvh": "^0.9.13",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "playwright": "^1.61.1",
    "vite": "^8.1.5"
  },
  "private": true
}
